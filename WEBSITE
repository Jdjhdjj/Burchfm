<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Level Up · gaming hub</title>
  <!-- Font Awesome 6 (free) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
    }

    body {
      background: #0d0f14;
      color: #e3e6f0;
      line-height: 1.5;
    }

    /* smooth scroll & container */
    html {
      scroll-behavior: smooth;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* ===== HEADER / NAV ===== */
    .navbar {
      background: #151a22;
      padding: 1rem 0;
      border-bottom: 2px solid #2f3b4b;
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(4px);
      background: rgba(21, 26, 34, 0.96);
    }

    .nav-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .logo {
      font-size: 1.9rem;
      font-weight: 800;
      letter-spacing: 1px;
      background: linear-gradient(135deg, #b16bf0, #5f9cf0);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .logo i {
      background: none;
      -webkit-text-fill-color: #b16bf0; 
      margin-right: 6px;
      font-size: 2rem;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      font-weight: 600;
    }

    .nav-links a {
      color: #bdc5d6;
      text-decoration: none;
      transition: 0.2s;
      font-size: 1.1rem;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .nav-links a i {
      font-size: 1rem;
      color: #7388b0;
    }

    .nav-links a:hover {
      color: white;
      text-shadow: 0 0 6px #5f9cf0;
    }

    .btn-outline {
      background: transparent;
      border: 2px solid #3d4e6b;
      border-radius: 40px;
      padding: 0.5rem 1.5rem;
      font-weight: 600;
      color: #d0daf5;
      transition: 0.2s;
      cursor: default;
    }
    .btn-outline i {
      margin-right: 6px;
    }
    .btn-outline:hover {
      border-color: #6f8fcf;
      background: #1f2a38;
    }

    /* ===== HERO ===== */
    .hero {
      background: linear-gradient(145deg, #10131e 0%, #1b212e 100%);
      padding: 4rem 0;
      border-bottom: 1px solid #2d3545;
    }

    .hero-grid {
      display: flex;
      align-items: center;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .hero-content {
      flex: 1 1 350px;
    }

    .hero-content h1 {
      font-size: 3.3rem;
      font-weight: 800;
      line-height: 1.2;
      background: linear-gradient(to right, #f0e9d8, #b2c9ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-content p {
      font-size: 1.2rem;
      color: #a2b6d9;
      margin: 1.5 0 2rem 0;
      max-width: 550px;
    }

    .hero-badge {
      background: #2d374b;
      border-radius: 60px;
      padding: 0.4rem 1.5rem;
      display: inline-block;
      margin-bottom: 1rem;
      border-left: 4px solid #9970db;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .hero-stats {
      display: flex;
      gap: 2rem;
      margin: 2rem 0;
    }
    .stat-item h3 {
      font-size: 1.8rem;
      color: white;
    }
    .stat-item span {
      color: #8da0c0;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1px;
    }

    .hero-image {
      flex: 1 1 350px;
      background: #212838;
      border-radius: 30px;
      padding: 1.5rem;
      box-shadow: 0 30px 30px -10px #00000066;
      border: 1px solid #3b455a;
    }

    .game-controller-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }
    .ctrl-icon {
      background: #2c364b;
      border-radius: 24px;
      padding: 1.5rem 1rem;
      text-align: center;
      font-size: 2.5rem;
      color: #84a2ff;
      border-bottom: 3px solid #4d6190;
    }
    .ctrl-icon small {
      display: block;
      font-size: 0.8rem;
      color: #b7c7ee;
      margin-top: 6px;
    }

    /* ===== FEATURED GAMES SECTION ===== */
    .section-title {
      font-size: 2.4rem;
      font-weight: 700;
      margin: 3rem 0 1.5rem 0;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-title i {
      color: #6d8ae0;
      font-size: 2.2rem;
    }

    .game-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .game-card {
      background: #1c222d;
      border-radius: 24px;
      padding: 1.4rem 1.4rem 2rem 1.4rem;
      transition: transform 0.25s, box-shadow 0.3s;
      border: 1px solid #323e54;
      box-shadow: 0 12px 15px -8px #00000080;
      display: flex;
      flex-direction: column;
    }

    .game-card:hover {
      transform: translateY(-8px);
      border-color: #657eb3;
      box-shadow: 0 25px 25px -10px #02060c;
    }

    .game-img {
      width: 100%;
      aspect-ratio: 1 / 1;
      background: #2c3447;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
      color: #6380cf;
      margin-bottom: 1.4rem;
      border: 1px solid #405073;
    }

    .game-category {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #86a0d9;
    }

    .game-card h3 {
      font-size: 1.8rem;
      font-weight: 600;
      margin: 0.2rem 0 0.3rem;
    }

    .game-meta {
      display: flex;
      justify-content: space-between;
      margin: 0.5rem 0 1rem 0;
      color: #9fb0d1;
      font-size: 0.95rem;
    }
    .game-meta i {
      margin-right: 4px;
      color: #e0b864;
    }

    .game-tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin: 0.5rem 0 1.5rem 0;
    }
    .tag {
      background: #262f41;
      border-radius: 30px;
      padding: 0.25rem 1rem;
      font-size: 0.8rem;
      color: #b7ceff;
    }

    .card-footer {
      margin-top: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .price {
      font-weight: 700;
      font-size: 1.5rem;
      color: #d4e0ff;
    }
    .price small {
      font-size: 0.9rem;
      font-weight: 400;
      color: #7b90b5;
    }
    .btn-download {
      background: #2b3e63;
      border: none;
      border-radius: 40px;
      padding: 0.6rem 1.5rem;
      color: white;
      font-weight: 600;
      cursor: default;
      transition: 0.15s;
    }
    .btn-download i {
      margin-right: 6px;
    }
    .btn-download:hover {
      background: #3b5585;
    }

    /* ===== GENRE BADGES / TRENDING ===== */
    .genre-strip {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 1rem;
      background: #151e2b;
      border-radius: 80px;
      padding: 0.8rem 2rem;
      margin: 2rem 0 3rem;
      border: 1px solid #31415a;
    }
    .genre-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      color: #adc0ea;
    }
    .genre-item i {
      background: #2f3d5a;
      padding: 8px;
      border-radius: 50%;
    }

    /* ===== LIVE STREAM / COMMUNITY ===== */
    .community-section {
      display: flex;
      gap: 2rem;
      margin: 4rem 0;
      flex-wrap: wrap;
    }
    .stream-panel {
      flex: 2 1 300px;
      background: #171f2b;
      border-radius: 40px;
      padding: 2rem;
      border: 1px solid #314864;
    }
    .stream-panel h2 {
      font-size: 2rem;
    }
    .stream-avatar {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 1.8rem 0;
    }
    .avatar {
      background: linear-gradient(145deg, #6e51b0, #2f539e);
      width: 60px;
      height: 60px;
      border-radius: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
    }
    .stream-info h4 {
      font-size: 1.3rem;
    }
    .live-badge {
      background: #c93b3b;
      border-radius: 40px;
      padding: 0.2rem 1rem;
      font-weight: 700;
      font-size: 0.8rem;
      display: inline-block;
      margin-top: 4px;
    }

    .right-panel {
      flex: 1 1 220px;
      background: #121a25;
      border-radius: 40px;
      padding: 2rem 1.5rem;
      border: 1px solid #2f4468;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .right-panel i {
      font-size: 2.8rem;
      color: #e3b35c;
    }

    /* ===== FOOTER ===== */
    footer {
      background: #0b1017;
      padding: 3rem 0;
      margin-top: 4rem;
      border-top: 1px solid #222e40;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 2rem;
    }
    .footer-col p {
      color: #8699bb;
      margin-top: 1rem;
    }
    .footer-col a {
      display: block;
      color: #98abcf;
      text-decoration: none;
      margin: 0.5rem 0;
    }
    .social-icons {
      display: flex;
      gap: 1rem;
      font-size: 1.8rem;
      margin-top: 1rem;
    }
    .copyright {
      text-align: center;
      color: #4d6085;
      margin-top: 3rem;
      font-size: 0.9rem;
    }

    /* responsive touches */
    @media (max-width: 700px) {
      .nav-container { flex-direction: column; gap: 1rem; }
      .hero-content h1 { font-size: 2.5rem; }
      .genre-strip { border-radius: 30px; justify-content: center; }
    }
  </style>
</head>
